{
  "name": "resource-properties-viewer",
  "displayName": "Resource Properties Viewer",
  "description": "Visual editor for Java .properties files with multi-locale support",
  "version": "0.1.0",
  "publisher": "adrianferrandis",
  "author": {
    "name": "Adrian Ferrandis Homsi"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "properties",
    "i18n",
    "localization",
    "resource bundle",
    "java",
    "viewer"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "homepage": "https://github.com/adrianferrandis/resource-properties-viewer#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/adrianferrandis/resource-properties-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/adrianferrandis/resource-properties-viewer/issues"
  },
  "activationEvents": [
    "onCustomEditor:resourcePropertiesViewer.propertiesViewer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "resourcePropertiesViewer.open",
        "title": "Open with Resource Properties Viewer",
        "category": "Resource Properties",
        "icon": "$(open-preview)"
      },
      {
        "command": "resourcePropertiesViewer.reload",
        "title": "Reload Resource Properties",
        "category": "Resource Properties",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "resourcePropertiesViewer.open",
          "when": "resourceExtname == .properties"
        }
      ],
      "editor/title": [
        {
          "command": "resourcePropertiesViewer.open",
          "when": "resourceExtname == .properties",
          "group": "navigation",
          "icon": "$(open-preview)"
        }
      ],
      "editor/context": [
        {
          "command": "resourcePropertiesViewer.open",
          "when": "resourceExtname == .properties",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "resourcePropertiesViewer.open",
          "when": "resourceExtname == .properties",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "resourcePropertiesViewer.propertiesViewer",
        "displayName": "Resource Properties Viewer",
        "selector": [
          {
            "filenamePattern": "*.properties"
          }
        ],
        "priority": "option"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Resource Properties Viewer",
      "properties": {
        "resourcePropertiesViewer.showRelatedFiles": {
          "type": "boolean",
          "default": true,
          "description": "Show related locale files in the viewer"
        },
        "resourcePropertiesViewer.defaultLocale": {
          "type": "string",
          "default": "en",
          "description": "Default locale to display when multiple locales are present"
        },
        "resourcePropertiesViewer.unicodeEscapeDefault": {
          "type": "boolean",
          "default": true,
          "description": "Whether to show Unicode escapes by default (\\uXXXX)"
        },
        "resourcePropertiesViewer.keySeparator": {
          "type": "string",
          "default": ".",
          "description": "Separator used to split hierarchical keys (e.g. 'ui.dialog.ok')"
        }
      }
    }
  },
  "scripts": {
    "build": "pnpm exec node esbuild.mjs",
    "watch": "pnpm exec node esbuild.mjs --watch",
    "test": "node ./out/test/runTest.js",
    "vscode:prepublish": "pnpm run build",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@vscode/vsce-sign",
      "keytar"
    ],
    "overrides": {
      "serialize-javascript": "7.0.5"
    }
  },
  "devDependencies": {
    "@types/glob": "8.1.0",
    "@types/mocha": "10.0.10",
    "@types/node": "18.19.86",
    "@types/vscode": "1.99.1",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.3.2",
    "esbuild": "0.25.3",
    "glob": "10.5.0",
    "jsdom": "^29.1.1",
    "mocha": "11.2.2",
    "typescript": "5.8.3"
  }
}
